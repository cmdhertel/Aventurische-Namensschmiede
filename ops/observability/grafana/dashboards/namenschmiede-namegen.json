      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "sum(rate(namegen_generate_count_total{namegen_region=~\"$region\", namegen_mode=~\"$mode\"}[5m]))", "legendFormat": "Gen/s", "range": true, "refId": "A" }],
