      "targets": [
        { "datasource": { "type": "loki", "uid": "loki" }, "editorMode": "code", "expr": "sum(rate({service=~\"$service\"}[$__interval]))", "legendFormat": "lines/s", "queryType": "range", "refId": "A" }
      ],
      "title": "Log Rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
