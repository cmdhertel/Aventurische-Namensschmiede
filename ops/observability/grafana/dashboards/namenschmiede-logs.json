        { "datasource": { "type": "loki", "uid": "loki" }, "editorMode": "code", "expr": "sum(count_over_time({service=~\"$service\", level=\"WARNING\"}[$__interval]))", "legendFormat": "WARNING", "queryType": "range", "refId": "B" }
